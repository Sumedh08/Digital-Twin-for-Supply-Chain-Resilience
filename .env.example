# CarbonShip Environment Configuration
# Copy this to .env and update values

# Secret key for JWT authentication (generate with: python -c "import secrets; print(secrets.token_hex(32))")
CARBONSHIP_SECRET_KEY=your-super-secret-key-here-change-in-production

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Database (for future PostgreSQL migration)
# DATABASE_URL=postgresql://user:password@localhost:5432/carbonship

# External API Keys (optional)
# Register at https://aisstream.io for live AIS data
AIS_STREAM_API_KEY=

# EU ETS API (if using paid service)
ETS_API_KEY=
